# Docker Compose - Auth stack environment

# Common
AUTH_RESTART_POLICY=unless-stopped

# Mongo
AUTH_MONGO_IMAGE=mongo:7
AUTH_MONGO_CONTAINER_NAME=auth-mongo
AUTH_MONGO_PORT=27017
MONGO_DB_NAME=auth_db

# RabbitMQ
AUTH_RABBITMQ_IMAGE=rabbitmq:3.13-management
AUTH_RABBITMQ_CONTAINER_NAME=auth-rabbitmq
AUTH_RABBITMQ_PORT=5672
AUTH_RABBITMQ_MANAGEMENT_PORT=15672

# Auth service
AUTH_SERVICE_CONTAINER_NAME=auth-service
AUTH_SERVICE_PORT=8081
SERVICE_NAME=auth-service
HTTP_PORT=8081
LOG_LEVEL=info
REQUEST_TIMEOUT_SECONDS=10
MONGO_URI=mongodb://auth-mongo:27017
RABBITMQ_URL=amqp://guest:guest@auth-rabbitmq:5672/
JWT_SECRET=change-me-in-real-env
JWT_ISSUER=auth-service
JWT_ACCESS_TTL=15
JWT_REFRESH_TTL=10080
BCRYPT_COST=12
